{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@acme/common": ["packages/common/src/index.ts"],
      "@acme/api": ["packages/api/src/index.ts"],
      "@acme/db": ["packages/db/src/index.ts"],
      "@acme/api/*": ["packages/api/src/*"],
      "@acme/common/*": ["packages/common/src/*"],
      "@acme/db/*": ["packages/db/src/*"]
    }
  }
}
